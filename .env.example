# Resume Scanner — Gemini API key
# Get your free key at: https://aistudio.google.com/app/apikey
# Add this to your Vercel project under Settings > Environment Variables
GEMINI_API_KEY=

# Resume Scanner — Firebase Admin SDK (used for per-IP daily rate limiting
# on the analyze/fix-chat API routes via Firestore). This is a SEPARATE
# credential from the public firebaseConfig in src/lib/firebase.js — it's
# a service account key and must never be committed or exposed client-side.
# Get these from Firebase Console > Project Settings > Service Accounts >
# Generate new private key (use the offerbound-ed972 project).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
